#1toN with for

#include <iostream>
using namespace std;

int main(){

for(int i=0;i<=10;i++){
  cout<<<<"\n";
}

return 0;
}


#Nto1 with for

#include <iostream>
using namespace std;

int main(){

for(int i=10;i>=1;i--){
  cout<<i<<" ";
}

return 0;
}

##1toN with while

#include <iostream>
using namespace std;

int main(){
int i=1;
while(i<=10){
  cout<<i<<" ";
  i++;
}
return 0;
}

##Nto1 with while

#include <iostream>
using namespace std;

int main(){
int i=10;
while(i>=1){
  cout<<i<<" ";
  i--;
}
return 0;
}

#1toN with doWhile

#include <iostream>
using namespace std;

int main(){
int i=1;
do{
  cout<<i<<" ";
  i++;
}while(i<=10);

return 0;
}

