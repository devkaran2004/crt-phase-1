#Prime number 

#include <iostream>
using namespace std;

int main(){
int n;
cin>>n;
bool isPrime=true;
if(n<2){
  isPrime=false;
}else{
 for (int i=2;i<n;i++){
  if(n%i==0){
     isPrime=false;
     break;
  }
 }
}
if(isPrime){
  cout<<"prime";
}else{
  cout<<"non prime";
}
return 0;
}

