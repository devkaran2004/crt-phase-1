#1toN with for

#include <iostream>
using namespace std;

int main(){

for(int i=0;i<=10;i++){
  cout<<<<"\n";
}

return 0;
}


#Nto1 with for

#include <iostream>
using namespace std;

int main(){

for(int i=10;i>=1;i--){
  cout<<i<<" ";
}

return 0;
}

##1toN with while

#include <iostream>
using namespace std;

int main(){
int i=1;
while(i<=10){
  cout<<i<<" ";
  i++;
}
return 0;
}

##Nto1 with while

#include <iostream>
using namespace std;

int main(){
int i=10;
while(i>=1){
  cout<<i<<" ";
  i--;
}
return 0;
}

#1toN with doWhile

#include <iostream>
using namespace std;

int main(){
int i=1;
do{
  cout<<i<<" ";
  i++;
}while(i<=10);

return 0;
}

#Nto1 with doWhile


#include <iostream>
using namespace std;

int main(){
int i=10;
do{
  cout<<i<<" ";
  i--;
}while(i>=1);

return 0;
}

#factorial using for

#include <iostream>
using namespace std;

int main(){
int n;
cin>>n;
int fact=1;

for(int i=n;i>=1;i--){
  fact= fact*i;
  
}
cout<<fact;
return 0;
}


#fibonacci series

#include <iostream>
using namespace std;

int main(){
int n;
cin>>n;
int c;
int a=0;
int b=1;
 
for(int i=0;i<n;i++){
cout<<a<<" ";
c=a+b;
a=b;
b=c;
}

return 0;
}

