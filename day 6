#call by avlue and refrence

//value is a photocopy
//refernce is original copy adddress

#include <iostream>
using namespace std;

void value(int x){
    x=500;
}
void ref(int &x){
    x=500;
}

int main(){
int a=100;

value(a);
cout<<a<<endl;

ref(a);
cout<<a;
}

