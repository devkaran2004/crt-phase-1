#mirrored right angle triangle 
#include <iostream>
using namespace std;

int main() {
    int n;
    
    cin >> n;

    for (int i = 1; i <= n; i++) {
        // Step 1: Print spaces (n - i)
        for (int j = n-i; j >= 1; j--) {
            cout << " ";
        }
        
        
        for (int k = 1; k <= i; k++) {
            cout << "*";
        }
        
        
        cout << "\n";
    }

    return 0;
}

