//if else

#include <iostream>
using namespace std;

int main(){

   int age;
   cin>>age;

   if(age>=18){
    cout<<"eligible for vote";
   } else {
    cout<<"not eligible for vote";
   }
    return 0;
}

//nested if else

#include <iostream>
using namespace std;

int main(){

   int age;
   cin>>age;

   if(age>=18){
       if(age>=100){
        cout<<"can vote but a senior citizen";
       }else{
        cout<<"can vote ";
       } 
   } else {  
    if(age<0){
    cout<<"enter valid age";
} else {
    cout<<"cant vote ";
} 
}
    return 0;
}

