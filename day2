   cin>>a>>b;

   max=(a>b)? a:b;
    cout<<max;
return 0;
}

//continue statement
#include <iostream>
using namespace std;

int main(){
int n;
cin>>n;

for(int i=1;i<=n;i++){
  if(i%3==0){
    continue;
  }
  cout<<i<<" ";

}
return 0;
}


//break statement

#include <iostream>
using namespace std;

int main(){
int n;
cin>>n;

for(int i=1;i<=n;i++){
  if(i%3==0){
    break;
  }
  cout<<i<<" ";

}
return 0;
}




