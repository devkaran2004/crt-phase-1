#function overloading
#include <iostream>
using namespace std;
int add(int a ,int b){
    return a+b;
}
int add(int a ,int b,int c){
    return a+b+c;
}
int add(int a ,int b,int c, int d){
    return a+b+c+d;
}

double add(double a ,double b){
    return a+b;
}
int main(){
  cout<<add(5,6)<<endl;
  cout<<add(5,6,7)<<endl;
  cout<<add(5,6,7,8)<<endl;
  cout<<add(5.0,6.3)<<endl;
 return 0;

}


